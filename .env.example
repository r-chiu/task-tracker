# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # Generate with: openssl rand -base64 32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack
SLACK_BOT_TOKEN=  # xoxb-... from your Slack app
SLACK_SIGNING_SECRET=

# Cron Authentication
CRON_SECRET=  # Any random string for authenticating cron job requests

# AI-powered task parsing (optional — falls back to regex if not set or credits run out)
ANTHROPIC_API_KEY=  # sk-ant-... from console.anthropic.com

# Local Ollama fallback (optional — used when Anthropic is unavailable)
OLLAMA_BASE_URL=http://localhost:11434  # Default Ollama endpoint
OLLAMA_MODEL=gpt-oss  # Model name in your Ollama instance

# Admin Setup
ADMIN_EMAIL=  # Email of the admin user (Ray)
RAY_SLACK_USER_ID=  # Ray's Slack user ID for weekly report delivery
SLACK_IMPORTANT_DMS=  # Comma-separated DM channel IDs to always include
